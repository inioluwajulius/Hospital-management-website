{
  "buildCommand": "cd hospital-frontend && npm run build",
  "outputDirectory": "hospital-frontend/dist",
  "public": "hospital-frontend/dist",
  "env": {
    "NODE_ENV": "production",
    "MONGODB_URI": "@mongodb_uri"
  },
  "functions": {
    "api/index.js": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
